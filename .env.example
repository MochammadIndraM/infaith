# ── Supabase (RSVP & Guestbook) ─────────────────────────────
# Ambil dari: Supabase Dashboard → Project Settings → Data API / API Keys
# Salin file ini jadi `.env.local` untuk dev, dan set variabel yang sama di Vercel.
# Bila kosong, situs otomatis pakai mock (data tidak tersimpan).
#
# PENTING: URL = base project saja, TANPA "/rest/v1/" di belakang.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ── Halaman admin /admin (rekap RSVP) ───────────────────────
# Service/secret key Supabase — SERVER-ONLY, JANGAN pakai prefix NEXT_PUBLIC.
# Ambil di Dashboard → API Keys → "service_role" (legacy) atau "secret" (sb_secret_...).
SUPABASE_SERVICE_ROLE_KEY=
# Login Basic Auth untuk buka /admin. Bila kosong, /admin ditolak (default-deny).
ADMIN_USER=
ADMIN_PASSWORD=

# ── Domain kanonik (opsional) ───────────────────────────────
# Set hanya bila pakai custom domain (untuk OG image/preview WhatsApp).
# Di Vercel tanpa custom domain, ini otomatis dari VERCEL_PROJECT_PRODUCTION_URL.
# NEXT_PUBLIC_SITE_URL=https://undangan-kami.com
